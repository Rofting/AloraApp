<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F0F4F8"> <TextView
    android:id="@+id/tvTituloAsistente"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Alora te escucha"
    android:textSize="26sp"
    android:textStyle="bold"
    android:textColor="#333333"
    android:layout_centerHorizontal="true"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tvTextoPaciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTituloAsistente"
        android:text="Toca el micrófono y cuéntame cómo te sientes hoy..."
        android:textSize="18sp"
        android:textColor="#555555"
        android:textAlignment="center"
        android:textStyle="italic"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvRespuestaIA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTextoPaciente"
        android:text=""
        android:textSize="20sp"
        android:textColor="#0277BD"
        android:textAlignment="center"
        android:textStyle="bold"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:fabCustomSize="80dp"
        app:tint="@android:color/white"
        android:backgroundTint="#FF4081"
        android:contentDescription="Hablar"/>

</RelativeLayout>